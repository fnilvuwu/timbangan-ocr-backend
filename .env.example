APP_NAME=ScaleScan API
APP_ENV=development
DATABASE_URL=sqlite:///./scalescan.db
UPLOAD_DIR=uploads
SECRET_KEY=dev-only-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_ORIGIN=http://localhost:3000
# GEMINI (Gemma) API key for Google Generative AI
GEMINI_API_KEY=your_api_key_here

# Optionally override default Gemma model
# GEMINI_MODEL=gemma-4-31b-it
ADMIN_EMAIL=youradmin@custom.com
ADMIN_PASSWORD=yoursecurepassword